{
	"info": {
		"_postman_id": "a9010eb8-7a54-46ab-a070-cf824da5eb20",
		"name": "2.1.14 Test Middleware Role",
		"description": "Collection untuk menguji Middleware Authentication & Role (200 OK & 403 Forbidden)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. GET Admin Dashboard - 200 OK (With Admin Token)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{admin_token}}",
							"type": "string"
						}
					]
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/admin/test",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"admin",
						"test"
					]
				},
				"description": "Mengakses rute /api/admin/test menggunakan token Admin. Expected result: 200 OK"
			},
			"response": []
		},
		{
			"name": "2. GET Admin Dashboard - 403 Forbidden (With User Token)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{user_token}}",
							"type": "string"
						}
					]
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/admin/test",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"admin",
						"test"
					]
				},
				"description": "Mengakses rute /api/admin/test menggunakan token User biasa. Expected result: 403 Forbidden"
			},
			"response": []
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login as Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if(response.success && response.data && response.data.token) {",
									"    pm.collectionVariables.set(\"admin_token\", response.data.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"email\": \"admin@example.com\",\r\n    \"password\": \"Password123!\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/signin",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"signin"
							]
						}
					},
					"response": []
				},
				{
					"name": "Login as User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if(response.success && response.data && response.data.token) {",
									"    pm.collectionVariables.set(\"user_token\", response.data.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"email\": \"user@example.com\",\r\n    \"password\": \"Password123!\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/signin",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"signin"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8000"
		},
		{
			"key": "admin_token",
			"value": ""
		},
		{
			"key": "user_token",
			"value": ""
		}
	]
}
