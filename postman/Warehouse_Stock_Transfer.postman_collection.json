{
  "info": {
    "name": "Warehouse Stock Transfer",
    "description": "Transfer stock between stores with atomic transaction\n\nCredentials:\n- SUPER_ADMIN: admin@example.com / Password123!\n\nSeed Data:\n- Store 1: Grosur Pusat Jakarta (50 Beras)\n- Store 2: Grosur Cabang Bandung (20 Beras)\n- Sample transfer: 10 units Jakarta → Bandung",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as SUPER_ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/signin",
              "host": ["{{base_url}}"],
              "path": ["auth", "signin"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data.token) {",
                  "  pm.collectionVariables.set('access_token', response.data.token);",
                  "  console.log('SUPER_ADMIN token saved');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Stock Transfer",
      "item": [
        {
          "name": "Transfer Stock (Jakarta → Bandung)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"b4b2fd3e-baa5-4429-b3e1-709af8363509\",\n  \"fromStoreId\": \"9e30396f-08b5-4c15-8b99-35b9f14e1f98\",\n  \"toStoreId\": \"store-bandung-uuid-here\",\n  \"quantity\": 10,\n  \"reason\": \"Restock cabang Bandung untuk persiapan promo\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/stocks/transfer",
              "host": ["{{base_url}}"],
              "path": ["stocks", "transfer"]
            }
          }
        },
        {
          "name": "Transfer Stock (Small Quantity)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"b4b2fd3e-baa5-4429-b3e1-709af8363509\",\n  \"fromStoreId\": \"9e30396f-08b5-4c15-8b99-35b9f14e1f98\",\n  \"toStoreId\": \"store-bandung-uuid-here\",\n  \"quantity\": 5,\n  \"reason\": \"Emergency restock\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/stocks/transfer",
              "host": ["{{base_url}}"],
              "path": ["stocks", "transfer"]
            }
          }
        },
        {
          "name": "Transfer Stock (Test Insufficient - Should Fail)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"b4b2fd3e-baa5-4429-b3e1-709af8363509\",\n  \"fromStoreId\": \"9e30396f-08b5-4c15-8b99-35b9f14e1f98\",\n  \"toStoreId\": \"store-bandung-uuid-here\",\n  \"quantity\": 9999,\n  \"reason\": \"Test insufficient stock validation\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/stocks/transfer",
              "host": ["{{base_url}}"],
              "path": ["stocks", "transfer"]
            }
          }
        },
        {
          "name": "Transfer Stock (Same Store - Should Fail)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"b4b2fd3e-baa5-4429-b3e1-709af8363509\",\n  \"fromStoreId\": \"9e30396f-08b5-4c15-8b99-35b9f14e1f98\",\n  \"toStoreId\": \"9e30396f-08b5-4c15-8b99-35b9f14e1f98\",\n  \"quantity\": 10,\n  \"reason\": \"Test same store validation\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/stocks/transfer",
              "host": ["{{base_url}}"],
              "path": ["stocks", "transfer"]
            }
          }
        },
        {
          "name": "Transfer Stock (Without Reason)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"b4b2fd3e-baa5-4429-b3e1-709af8363509\",\n  \"fromStoreId\": \"9e30396f-08b5-4c15-8b99-35b9f14e1f98\",\n  \"toStoreId\": \"store-bandung-uuid-here\",\n  \"quantity\": 3\n}"
            },
            "url": {
              "raw": "{{base_url}}/stocks/transfer",
              "host": ["{{base_url}}"],
              "path": ["stocks", "transfer"]
            }
          }
        }
      ]
    },
    {
      "name": "Verify Transfer",
      "item": [
        {
          "name": "Get Transfer Journals",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/stocks/journals?type=TRANSFER&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["stocks", "journals"],
              "query": [
                {
                  "key": "type",
                  "value": "TRANSFER"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Product Stock in Jakarta",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products?storeId=9e30396f-08b5-4c15-8b99-35b9f14e1f98&search=Beras",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                {
                  "key": "storeId",
                  "value": "9e30396f-08b5-4c15-8b99-35b9f14e1f98"
                },
                {
                  "key": "search",
                  "value": "Beras"
                }
              ]
            }
          }
        },
        {
          "name": "Get Product Stock in Bandung",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products?storeId=store-bandung-uuid-here&search=Beras",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                {
                  "key": "storeId",
                  "value": "store-bandung-uuid-here"
                },
                {
                  "key": "search",
                  "value": "Beras"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Reference Data",
      "item": [
        {
          "name": "Get All Stores (Find IDs)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/stores",
              "host": ["{{base_url}}"],
              "path": ["stores"]
            }
          }
        },
        {
          "name": "Get Products (Find IDs)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products?storeId=9e30396f-08b5-4c15-8b99-35b9f14e1f98&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                {
                  "key": "storeId",
                  "value": "9e30396f-08b5-4c15-8b99-35b9f14e1f98"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
