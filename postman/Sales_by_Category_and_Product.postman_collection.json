    {
      "name": "Top Selling Products",
      "item": [
        {
          "name": "Get Top 10 Selling Products (By Quantity)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Has top selling products', function () {",
                  "    pm.expect(response.data.topSellingProducts).to.be.an('array');",
                  "    pm.expect(response.data.topSellingProducts.length).to.be.greaterThan(0);",
                  "    pm.expect(response.data.topSellingProducts.length).to.be.lessThanOrEqual(10);",
                  "});",
                  "",
                  "pm.test('Each top product has required fields', function () {",
                  "    const product = response.data.topSellingProducts[0];",
                  "    pm.expect(product).to.have.property('productId');",
                  "    pm.expect(product).to.have.property('productName');",
                  "    pm.expect(product).to.have.property('quantity');",
                  "    pm.expect(product).to.have.property('revenue');",
                  "    pm.expect(product).to.have.property('transactions');",
                  "});",
                  "",
                  "pm.test('Top products sorted by quantity (descending)', function () {",
                  "    const products = response.data.topSellingProducts;",
                  "    if (products.length > 1) {",
                  "        for (let i = 0; i < products.length - 1; i++) {",
                  "            pm.expect(products[i].quantity).to.be.greaterThanOrEqual(products[i+1].quantity);",
                  "        }",
                  "    }",
                  "});",
                  "",
                  "console.log('=== TOP 10 SELLING PRODUCTS (By Quantity) ===');",
                  "response.data.topSellingProducts.forEach((prod, idx) => {",
                  "    console.log(`${idx + 1}. ${prod.productName}: ${prod.quantity} units (Rp ${prod.revenue.toLocaleString('id-ID')}, ${prod.transactions} transactions)`);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sales?month=1&year=2024",
