        {
          "name": "Compare Top Products vs Revenue Leaders",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "const topByQty = response.data.topSellingProducts;",
                  "const topByRevenue = response.data.byProduct;",
                  "",
                  "console.log('=== COMPARISON: Top by Quantity vs Top by Revenue ===');",
                  "console.log('\\nTop by Quantity:');",
                  "topByQty.slice(0, 3).forEach((prod, idx) => {",
                  "    console.log(`${idx + 1}. ${prod.productName}: ${prod.quantity} units`);",
                  "});",
                  "",
                  "console.log('\\nTop by Revenue:');",
                  "topByRevenue.slice(0, 3).forEach((prod, idx) => {",
                  "    console.log(`${idx + 1}. ${prod.productName}: Rp ${prod.revenue.toLocaleString('id-ID')}`);",
                  "});",
                  "",
                  "// Check if #1 by quantity is different from #1 by revenue",
                  "if (topByQty.length > 0 && topByRevenue.length > 0) {",
                  "    const qtyLeader = topByQty[0].productName;",
                  "    const revLeader = topByRevenue[0].productName;",
                  "    console.log(`\\nQuantity Leader: ${qtyLeader}`);",
                  "    console.log(`Revenue Leader: ${revLeader}`);",
                  "    if (qtyLeader !== revLeader) {",
                  "        console.log('⚠️ Different leaders! High-volume low-price vs low-volume high-price strategy.');",
                  "    } else {",
                  "        console.log('✅ Same leader in both metrics!');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sales?month=1&year=2024",
              "host": ["{{baseUrl}}"],
              "path": ["sales"],
              "query": [
                {
                  "key": "month",
                  "value": "1"
                },
                {
                  "key": "year",
                  "value": "2024"
                }
              ]
            }
          },
          "response": []
        }
      ]
