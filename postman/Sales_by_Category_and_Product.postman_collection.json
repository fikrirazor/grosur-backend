        {
          "name": "Get Sales by Product with Category Info",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Products include category information', function () {",
                  "    const product = response.data.byProduct[0];",
                  "    pm.expect(product).to.have.property('categoryId');",
                  "    pm.expect(product).to.have.property('categoryName');",
                  "});",
                  "",
                  "// Group products by category",
                  "const byCat = {};",
                  "response.data.byProduct.forEach(prod => {",
                  "    if (!byCat[prod.categoryName]) {",
                  "        byCat[prod.categoryName] = [];",
                  "    }",
                  "    byCat[prod.categoryName].push(prod);",
                  "});",
                  "",
                  "console.log('=== PRODUCTS GROUPED BY CATEGORY ===');",
                  "Object.keys(byCat).forEach(catName => {",
                  "    console.log(`\\n${catName}:`);",
                  "    byCat[catName].forEach(prod => {",
                  "        console.log(`  - ${prod.productName}: ${prod.quantity} units`);",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sales?month=1&year=2024",
              "host": ["{{baseUrl}}"],
              "path": ["sales"],
              "query": [
                {
                  "key": "month",
                  "value": "1"
                },
                {
                  "key": "year",
                  "value": "2024"
                }
              ]
            }
          },
          "response": []
        }
      ]
