{
  "info": {
    "name": "Sales by Category and Product",
    "description": "API testing for Sales Aggregation by Category, Product, and Top Selling Products (US-2.5.2)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "storeId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as SUPER_ADMIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data?.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', response.data.accessToken);",
                  "    console.log('SUPER_ADMIN token saved');",
                  "}",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Sales by Category",
      "item": [
        {
          "name": "Get Sales by Category (January 2024)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Has category aggregation', function () {",
                  "    pm.expect(response.data.byCategory).to.be.an('array');",
                  "    pm.expect(response.data.byCategory.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Each category has required fields', function () {",
                  "    const category = response.data.byCategory[0];",
                  "    pm.expect(category).to.have.property('categoryId');",
                  "    pm.expect(category).to.have.property('categoryName');",
                  "    pm.expect(category).to.have.property('quantity');",
                  "    pm.expect(category).to.have.property('revenue');",
                  "    pm.expect(category).to.have.property('products');",
                  "});",
                  "",
                  "pm.test('Categories sorted by revenue (descending)', function () {",
                  "    const categories = response.data.byCategory;",
                  "    if (categories.length > 1) {",
                  "        for (let i = 0; i < categories.length - 1; i++) {",
                  "            pm.expect(categories[i].revenue).to.be.greaterThanOrEqual(categories[i+1].revenue);",
                  "        }",
                  "    }",
                  "});",
                  "",
                  "console.log('=== SALES BY CATEGORY ===');",
                  "response.data.byCategory.forEach(cat => {",
                  "    console.log(`${cat.categoryName}: Rp ${cat.revenue.toLocaleString('id-ID')} (${cat.quantity} units, ${cat.products} products)`);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sales?month=1&year=2024&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["sales"],
              "query": [
                {
                  "key": "month",
                  "value": "1"
                },
                {
                  "key": "year",
                  "value": "2024"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          },
          "response": []
        },
