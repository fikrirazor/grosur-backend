{
	"info": {
		"_postman_id": "inventory-management-v3",
		"name": "3. Inventory Management",
		"description": "API testing for Stock Management and Stock Journaling (History based).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login as SUPER_ADMIN",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.success && response.data.accessToken) {",
									"    pm.collectionVariables.set('accessToken', response.data.accessToken);",
									"    console.log('Token saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"Password123!\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					}
				}
			]
		},
		{
			"name": "Stock Management",
			"item": [
				{
					"name": "Get All Stocks (Filter by Store)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/stocks?storeId={{storeId}}&page=1&limit=20",
							"host": ["{{baseUrl}}"],
							"path": ["stocks"],
							"query": [
								{ "key": "storeId", "value": "{{storeId}}" },
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "20" }
							]
						}
					}
				},
				{
					"name": "Create/Initialize Stock",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"productId\": \"{{productId}}\",\n    \"storeId\": \"{{storeId}}\",\n    \"quantity\": 0\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/stocks",
							"host": ["{{baseUrl}}"],
							"path": ["stocks"]
						}
					}
				},
				{
					"name": "Update Stock (Via Journal Entry)",
					"request": {
						"method": "PATCH",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"productId\": \"{{productId}}\",\n    \"storeId\": \"{{storeId}}\",\n    \"change\": 10,\n    \"reason\": \"Restock Bulanan\",\n    \"userId\": \"{{userId}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/stocks/update",
							"host": ["{{baseUrl}}"],
							"path": ["stocks", "update"]
						}
					}
				},
				{
					"name": "Warehouse Stock Transfer",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"productId\": \"{{productId}}\",\n    \"fromStoreId\": \"{{storeId}}\",\n    \"toStoreId\": \"other-store-id\",\n    \"quantity\": 5,\n    \"reason\": \"Transfer ke cabang baru\",\n    \"userId\": \"{{userId}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/stocks/transfer",
							"host": ["{{baseUrl}}"],
							"path": ["stocks", "transfer"]
						}
					}
				},
				{
					"name": "Delete Stock Entry",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/stocks/:stockId",
							"host": ["{{baseUrl}}"],
							"path": ["stocks", ":stockId"],
							"variable": [
								{ "key": "stockId", "value": "stock-uuid" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Stock History (Journals)",
			"item": [
				{
					"name": "List Stock Journals (History)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/stocks/journals?storeId={{storeId}}&page=1&limit=20",
							"host": ["{{baseUrl}}"],
							"path": ["stocks", "journals"],
							"query": [
								{ "key": "storeId", "value": "{{storeId}}" },
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "20" }
							]
						}
					}
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:5000/api", "type": "string" },
		{ "key": "accessToken", "value": "", "type": "string" },
		{ "key": "storeId", "value": "", "type": "string" },
		{ "key": "productId", "value": "", "type": "string" },
		{ "key": "userId", "value": "", "type": "string" }
	]
}
