{
	"info": {
		"_postman_id": "discount-management-v4",
		"name": "4. Discount Management",
		"description": "API testing for Manual, Min Purchase, and BOGO discounts (Percentage & Nominal).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login as SUPER_ADMIN",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.success && response.data.accessToken) {",
									"    pm.collectionVariables.set('accessToken', response.data.accessToken);",
									"    console.log('Token saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"Password123!\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					}
				}
			]
		},
		{
			"name": "Discount Management (CRUD)",
			"item": [
				{
					"name": "Create Manual Discount (Nominal)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"type\": \"NOMINAL\",\n    \"value\": 5000,\n    \"productId\": \"{{productId}}\",\n    \"startDate\": \"2024-05-01T00:00:00Z\",\n    \"endDate\": \"2024-05-31T23:59:59Z\",\n    \"storeId\": \"{{storeId}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/discounts",
							"host": ["{{baseUrl}}"],
							"path": ["discounts"]
						}
					}
				},
				{
					"name": "Create Min Purchase Discount (Percentage with Limit)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"type\": \"PERCENTAGE\",\n    \"value\": 10,\n    \"minPurchase\": 100000,\n    \"maxDiscount\": 15000,\n    \"startDate\": \"2024-05-01T00:00:00Z\",\n    \"endDate\": \"2024-05-31T23:59:59Z\",\n    \"storeId\": \"{{storeId}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/discounts",
							"host": ["{{baseUrl}}"],
							"path": ["discounts"]
						}
					}
				},
				{
					"name": "Create BOGO (Buy One Get One) Discount",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"type\": \"BOGO\",\n    \"productId\": \"{{productId}}\",\n    \"startDate\": \"2024-05-01T00:00:00Z\",\n    \"endDate\": \"2024-05-31T23:59:59Z\",\n    \"storeId\": \"{{storeId}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/discounts",
							"host": ["{{baseUrl}}"],
							"path": ["discounts"]
						}
					}
				},
				{
					"name": "List Store Discounts (Management Page)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/discounts?storeId={{storeId}}",
							"host": ["{{baseUrl}}"],
							"path": ["discounts"],
							"query": [
								{ "key": "storeId", "value": "{{storeId}}" }
							]
						}
					}
				},
				{
					"name": "Update Discount",
					"request": {
						"method": "PATCH",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"value\": 20,\n    \"maxDiscount\": 25000\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/discounts/:discountId",
							"host": ["{{baseUrl}}"],
							"path": ["discounts", ":discountId"],
							"variable": [
								{ "key": "discountId", "value": "discount-uuid" }
							]
						}
					}
				},
				{
					"name": "Delete Discount",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/discounts/:discountId",
							"host": ["{{baseUrl}}"],
							"path": ["discounts", ":discountId"],
							"variable": [
								{ "key": "discountId", "value": "discount-uuid" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Apply Discount (Checkout Simulation)",
			"item": [
				{
					"name": "Check Available Discounts for Product",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/discounts/check?productId={{productId}}&storeId={{storeId}}",
							"host": ["{{baseUrl}}"],
							"path": ["discounts", "check"],
							"query": [
								{ "key": "productId", "value": "{{productId}}" },
								{ "key": "storeId", "value": "{{storeId}}" }
							]
						}
					}
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:5000/api", "type": "string" },
		{ "key": "accessToken", "value": "", "type": "string" },
		{ "key": "storeId", "value": "", "type": "string" },
		{ "key": "productId", "value": "", "type": "string" }
	]
}
