{
	"info": {
		"_postman_id": "product-management-v2",
		"name": "2. Product Management",
		"description": "API testing for Catalog, Search, Detail, and Product/Category management (Admin & Public).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login as SUPER_ADMIN",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.success && response.data.accessToken) {",
									"    pm.collectionVariables.set('accessToken', response.data.accessToken);",
									"    console.log('Token saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"Password123!\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					}
				}
			]
		},
		{
			"name": "Product Catalog and Product Search",
			"item": [
				{
					"name": "Get All Products (Catalog)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/products?page=1&limit=12&storeId={{storeId}}",
							"host": ["{{baseUrl}}"],
							"path": ["products"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "12" },
								{ "key": "storeId", "value": "{{storeId}}" }
							]
						}
					}
				},
				{
					"name": "Search Products",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/products?search=beras&categoryId={{categoryId}}",
							"host": ["{{baseUrl}}"],
							"path": ["products"],
							"query": [
								{ "key": "search", "value": "beras" },
								{ "key": "categoryId", "value": "{{categoryId}}" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Product Detail",
			"item": [
				{
					"name": "Get Product Detail by Slug",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/products/:slug?storeId={{storeId}}",
							"host": ["{{baseUrl}}"],
							"path": ["products", ":slug"],
							"query": [
								{ "key": "storeId", "value": "{{storeId}}" }
							],
							"variable": [
								{ "key": "slug", "value": "beras-premium-5kg" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Product Management (Admin)",
			"item": [
				{
					"name": "Create Product (Super Admin)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Produk Baru Postman\",\n    \"description\": \"Deskripsi produk lengkap\",\n    \"price\": 25000,\n    \"categoryId\": \"{{categoryId}}\",\n    \"storeId\": \"{{storeId}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/products",
							"host": ["{{baseUrl}}"],
							"path": ["products"]
						}
					}
				},
				{
					"name": "Update Product (Super Admin)",
					"request": {
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Produk Baru Updated\",\n    \"price\": 30000\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/products/:productId",
							"host": ["{{baseUrl}}"],
							"path": ["products", ":productId"],
							"variable": [
								{ "key": "productId", "value": "product-uuid" }
							]
						}
					}
				},
				{
					"name": "Delete Product (Super Admin)",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/products/:productId?storeId={{storeId}}",
							"host": ["{{baseUrl}}"],
							"path": ["products", ":productId"],
							"query": [
								{ "key": "storeId", "value": "{{storeId}}" }
							],
							"variable": [
								{ "key": "productId", "value": "product-uuid" }
							]
						}
					}
				},
				{
					"name": "Upload Product Images (Super Admin)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "images", "type": "file", "src": [] },
								{ "key": "images", "type": "file", "src": [] }
							]
						},
						"url": {
							"raw": "{{baseUrl}}/products/upload-images?productId={{productId}}&storeId={{storeId}}",
							"host": ["{{baseUrl}}"],
							"path": ["products", "upload-images"],
							"query": [
								{ "key": "productId", "value": "{{productId}}" },
								{ "key": "storeId", "value": "{{storeId}}" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Product Category Management (Admin)",
			"item": [
				{
					"name": "List Categories",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/categories?page=1&limit=10",
							"host": ["{{baseUrl}}"],
							"path": ["categories"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" }
							]
						}
					}
				},
				{
					"name": "Create Category (Super Admin)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Sembako\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/categories",
							"host": ["{{baseUrl}}"],
							"path": ["categories"]
						}
					}
				},
				{
					"name": "Update Category (Super Admin)",
					"request": {
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Sembako Premium\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/categories/:categoryId",
							"host": ["{{baseUrl}}"],
							"path": ["categories", ":categoryId"],
							"variable": [
								{ "key": "categoryId", "value": "category-uuid" }
							]
						}
					}
				},
				{
					"name": "Delete Category (Super Admin)",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/categories/:categoryId",
							"host": ["{{baseUrl}}"],
							"path": ["categories", ":categoryId"],
							"variable": [
								{ "key": "categoryId", "value": "category-uuid" }
							]
						}
					}
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:5000/api", "type": "string" },
		{ "key": "accessToken", "value": "", "type": "string" },
		{ "key": "storeId", "value": "", "type": "string" },
		{ "key": "categoryId", "value": "", "type": "string" },
		{ "key": "productId", "value": "", "type": "string" }
	]
}
