{
	"info": {
		"_postman_id": "report-analysis-v3",
		"name": "5. Report & Analysis",
		"description": "API testing for detailed Sales and Stock reports with filters.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login as SUPER_ADMIN",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.success && response.data.accessToken) {",
									"    pm.collectionVariables.set('accessToken', response.data.accessToken);",
									"    console.log('Token saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"Password123!\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					}
				}
			]
		},
		{
			"name": "Sales Report",
			"item": [
				{
					"name": "Monthly Sales Report (Overall/Filter Store)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/reports/sales?month=5&year=2024&storeId={{storeId}}",
							"host": ["{{baseUrl}}"],
							"path": ["reports", "sales"],
							"query": [
								{ "key": "month", "value": "5" },
								{ "key": "year", "value": "2024" },
								{ "key": "storeId", "value": "{{storeId}}" }
							]
						}
					}
				},
				{
					"name": "Sales Report by Category (Monthly)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/reports/sales?month=5&year=2024&groupBy=category",
							"host": ["{{baseUrl}}"],
							"path": ["reports", "sales"],
							"query": [
								{ "key": "month", "value": "5" },
								{ "key": "year", "value": "2024" },
								{ "key": "groupBy", "value": "category" }
							]
						}
					}
				},
				{
					"name": "Sales Report by Product (Monthly)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/reports/sales?month=5&year=2024&groupBy=product",
							"host": ["{{baseUrl}}"],
							"path": ["reports", "sales"],
							"query": [
								{ "key": "month", "value": "5" },
								{ "key": "year", "value": "2024" },
								{ "key": "groupBy", "value": "product" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Stock Report",
			"item": [
				{
					"name": "Stock Summary Report (Monthly Addition/Deduction/Final)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/reports/stock/summary?month=5&year=2024&storeId={{storeId}}",
							"host": ["{{baseUrl}}"],
							"path": ["reports", "stock", "summary"],
							"query": [
								{ "key": "month", "value": "5" },
								{ "key": "year", "value": "2024" },
								{ "key": "storeId", "value": "{{storeId}}" }
							]
						}
					}
				},
				{
					"name": "Detail Stock Report (Monthly History per Product)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/reports/stock/detail?productId={{productId}}&storeId={{storeId}}&month=5&year=2024",
							"host": ["{{baseUrl}}"],
							"path": ["reports", "stock", "detail"],
							"query": [
								{ "key": "productId", "value": "{{productId}}" },
								{ "key": "storeId", "value": "{{storeId}}" },
								{ "key": "month", "value": "5" },
								{ "key": "year", "value": "2024" }
							]
						}
					}
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:5000/api", "type": "string" },
		{ "key": "accessToken", "value": "", "type": "string" },
		{ "key": "storeId", "value": "", "type": "string" },
		{ "key": "productId", "value": "", "type": "string" }
	]
}
