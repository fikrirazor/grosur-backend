          }
        },
        {
          "name": "Get Store Discounts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/discounts?storeId={{store_id}}",
              "host": ["{{base_url}}"],
              "path": ["discounts"],
              "query": [
