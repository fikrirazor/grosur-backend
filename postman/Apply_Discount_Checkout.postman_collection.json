    {
      "name": "Reference Data",
      "item": [
        {
          "name": "Get User Vouchers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/vouchers",
              "host": ["{{base_url}}"],
