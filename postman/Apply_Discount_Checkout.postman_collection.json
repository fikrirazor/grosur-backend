{
  "info": {
    "name": "Apply Discount Checkout",
    "description": "Preview checkout with automatic discount & voucher calculation\n\nCredentials:\n- USER: user@example.com / Password123!\n\nSeed Data:\nActive Discounts:\n- Beras Premium: 20% OFF (max 50k)\n- Susu UHT: Buy 2 Get 1 Free\n- Bandung Store: Rp 15,000 OFF (store-wide)\n\nActive Vouchers:\n- WELCOME25: 25% off total (max 50k), min spend 100k\n- BERAS10K: Rp 10,000 off for Beras only\n- FREESHIP: Rp 15,000 shipping discount\n- USED50: Already used (for testing)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "store_id",
      "value": "9e30396f-08b5-4c15-8b99-35b9f14e1f98",
      "type": "string"
    },
    {
      "key": "product_beras",
      "value": "b4b2fd3e-baa5-4429-b3e1-709af8363509",
      "type": "string"
    },
    {
      "key": "product_susu",
      "value": "57ef4f11-371c-4327-b698-0df1fd29fcc3",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as USER",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/signin",
              "host": ["{{base_url}}"],
              "path": ["auth", "signin"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data.token) {",
                  "  pm.collectionVariables.set('access_token', response.data.token);",
                  "  console.log('USER token saved');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
