{
  "info": {
    "name": "Stock Management",
    "description": "Stock update with role-based store scoping and audit journal\n\nCredentials:\n- SUPER_ADMIN: admin@example.com / Password123!\n- STORE_ADMIN: storeadmin@example.com / Password123!\n\nNote: STORE_ADMIN automatically scoped to their assigned store",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as SUPER_ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/signin",
              "host": ["{{base_url}}"],
              "path": ["auth", "signin"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data.token) {",
                  "  pm.collectionVariables.set('access_token', response.data.token);",
                  "  console.log('SUPER_ADMIN token saved');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as STORE_ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"storeadmin@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/signin",
              "host": ["{{base_url}}"],
              "path": ["auth", "signin"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data.token) {",
                  "  pm.collectionVariables.set('access_token', response.data.token);",
                  "  console.log('STORE_ADMIN token saved');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Stock Operations",
      "item": [
        {
          "name": "Update Stock (Add Stock)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"b4b2fd3e-baa5-4429-b3e1-709af8363509\",\n  \"storeId\": \"9e30396f-08b5-4c15-8b99-35b9f14e1f98\",\n  \"change\": 10,\n  \"reason\": \"New shipment received from supplier\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/stocks/update",
              "host": ["{{base_url}}"],
              "path": ["stocks", "update"]
            }
          }
        },
        {
          "name": "Update Stock (Remove Stock)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"b4b2fd3e-baa5-4429-b3e1-709af8363509\",\n  \"storeId\": \"9e30396f-08b5-4c15-8b99-35b9f14e1f98\",\n  \"change\": -5,\n  \"reason\": \"Damaged goods - quality control\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/stocks/update",
              "host": ["{{base_url}}"],
              "path": ["stocks", "update"]
            }
          }
        },
        {
          "name": "Update Stock (Test Negative - Should Fail)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"b4b2fd3e-baa5-4429-b3e1-709af8363509\",\n  \"storeId\": \"9e30396f-08b5-4c15-8b99-35b9f14e1f98\",\n  \"change\": -9999,\n  \"reason\": \"Test insufficient stock validation\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/stocks/update",
              "host": ["{{base_url}}"],
              "path": ["stocks", "update"]
            }
          }
        },
        {
          "name": "Update Stock (Without Reason)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"b4b2fd3e-baa5-4429-b3e1-709af8363509\",\n  \"storeId\": \"9e30396f-08b5-4c15-8b99-35b9f14e1f98\",\n  \"change\": 3\n}"
            },
            "url": {
              "raw": "{{base_url}}/stocks/update",
              "host": ["{{base_url}}"],
              "path": ["stocks", "update"]
            }
          }
        }
      ]
    },
    {
      "name": "Reference Data",
      "item": [
        {
          "name": "Get All Products (Find IDs)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products?storeId=9e30396f-08b5-4c15-8b99-35b9f14e1f98&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                {
                  "key": "storeId",
                  "value": "9e30396f-08b5-4c15-8b99-35b9f14e1f98"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
