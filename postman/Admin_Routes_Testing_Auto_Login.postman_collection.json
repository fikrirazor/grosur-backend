{
	"info": {
		"_postman_id": "7f858f7e-fb86-4e56-bafb-9806443c2b87",
		"name": "Admin Routes Testing (Epic 2.2) Auto-Login",
		"description": "Postman Collection for testing Admin Role Guard / Middleware. Includes sign in requests to auto-fetch tokens.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Setup: Sign In as Admin",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"if(response.success && response.data && response.data.token) {",
							"    pm.collectionVariables.set(\"admin_token\", response.data.token);",
							"    console.log(\"Admin Token successfully saved to collection variables!\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    \"email\": \"admin@example.com\",\r\n    \"password\": \"Password123!\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/auth/signin",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"auth",
						"signin"
					]
				},
				"description": "Signs in an admin and automatically saves the token to the 'admin_token' variable. PLEASE UPDATE THE EMAIL AND PASSWORD in the Body to match your Admin account in the database."
			},
			"response": []
		},
		{
			"name": "2. Setup: Sign In as USER",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"if(response.success && response.data && response.data.token) {",
							"    pm.collectionVariables.set(\"user_token\", response.data.token);",
							"    console.log(\"User Token successfully saved to collection variables!\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    \"email\": \"user@example.com\",\r\n    \"password\": \"Password123!\"\r\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/auth/signin",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"auth",
						"signin"
					]
				},
				"description": "Signs in a normal user and automatically saves the token to the 'user_token' variable. PLEASE UPDATE THE EMAIL AND PASSWORD in the Body to match your User account in the database."
			},
			"response": []
		},
		{
			"name": "Admin Test - Without Token (Should Fail)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/admin/test",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"admin",
						"test"
					]
				},
				"description": "This request does not include a Bearer token, so it should return 401 Unauthorized."
			},
			"response": []
		},
		{
			"name": "Admin Test - With Valid Admin Token (Should Succeed)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{admin_token}}",
							"type": "string"
						}
					]
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/admin/test",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"admin",
						"test"
					]
				},
				"description": "This request uses a valid admin token (STORE_ADMIN or SUPER_ADMIN). It should return 200 OK."
			},
			"response": []
		},
		{
			"name": "Admin Test - With USER Token (Should Fail)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{user_token}}",
							"type": "string"
						}
					]
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/admin/test",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"admin",
						"test"
					]
				},
				"description": "This request uses a regular USER token. The roleGuard should block it and return 403 Forbidden."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "admin_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "user_token",
			"value": "",
			"type": "string"
		}
	]
}
