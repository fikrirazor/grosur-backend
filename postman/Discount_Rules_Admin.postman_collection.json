              "raw": "{\n  \"storeId\": \"9e30396f-08b5-4c15-8b99-35b9f14e1f98\",\n  \"type\": \"NOMINAL\",\n  \"value\": 20000,\n  \"minSpend\": 75000,\n  \"startDate\": \"2024-03-01T00:00:00Z\",\n  \"endDate\": \"2024-03-15T23:59:59Z\"\n}"
