{
  "info": {
    "name": "Product Detail",
    "description": "API testing for Product Detail with location-based stock context (US-2.2.2)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    },
    {
      "key": "storeId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as USER",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data?.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', response.data.accessToken);",
                  "    console.log('Access token saved');",
                  "}",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has access token', function () {",
                  "    pm.expect(response.data).to.have.property('accessToken');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Product Detail",
      "item": [
        {
          "name": "Get Product Detail by Store ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is successful', function () {",
                  "    pm.expect(response.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Product has required fields', function () {",
                  "    const product = response.data;",
                  "    pm.expect(product).to.have.property('id');",
                  "    pm.expect(product).to.have.property('name');",
                  "    pm.expect(product).to.have.property('price');",
                  "    pm.expect(product).to.have.property('stock');",
                  "    pm.expect(product).to.have.property('images');",
                  "    pm.expect(product).to.have.property('category');",
                  "});",
                  "",
                  "pm.test('Stock is a number', function () {",
                  "    pm.expect(response.data.stock).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Images is an array', function () {",
                  "    pm.expect(response.data.images).to.be.an('array');",
                  "});",
                  "",
                  "// Save productId for other tests",
                  "if (response.data && response.data.id) {",
                  "    pm.collectionVariables.set('productId', response.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}?storeId={{storeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"],
              "query": [
                {
                  "key": "storeId",
                  "value": "{{storeId}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Product Detail by Location (Nearest Store)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is successful', function () {",
                  "    pm.expect(response.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Product has stock from nearest store', function () {",
                  "    const product = response.data;",
                  "    pm.expect(product).to.have.property('stock');",
                  "    pm.expect(product.stock).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Product has images', function () {",
                  "    pm.expect(response.data.images).to.be.an('array');",
                  "    pm.expect(response.data.images.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Product has category info', function () {",
                  "    pm.expect(response.data.category).to.have.property('name');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}?userLat=-6.2088&userLong=106.8456",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"],
              "query": [
                {
                  "key": "userLat",
                  "value": "-6.2088",
                  "description": "Jakarta latitude"
                },
                {
                  "key": "userLong",
                  "value": "106.8456",
                  "description": "Jakarta longitude"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Product Detail - Stock Zero (Add to Cart Disabled)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Stock is zero or low', function () {",
                  "    // Frontend should disable Add to Cart if stock === 0",
                  "    pm.expect(response.data.stock).to.be.a('number');",
                  "    console.log('Stock quantity:', response.data.stock);",
                  "});",
                  "",
                  "pm.test('Product details complete for display', function () {",
                  "    const product = response.data;",
                  "    pm.expect(product).to.have.property('name');",
                  "    pm.expect(product).to.have.property('description');",
                  "    pm.expect(product).to.have.property('price');",
                  "    pm.expect(product).to.have.property('images');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}?storeId={{storeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"],
              "query": [
                {
                  "key": "storeId",
                  "value": "{{storeId}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Validation Tests",
      "item": [
        {
          "name": "Test Invalid Product ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Error message indicates product not found', function () {",
                  "    pm.expect(response.message).to.include('not found');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/invalid-product-id?storeId={{storeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "invalid-product-id"],
              "query": [
                {
                  "key": "storeId",
                  "value": "{{storeId}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Test Missing Parameters",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message indicates missing params', function () {",
                  "    pm.expect(response.message).to.include('required');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"],
              "query": []
            }
          },
          "response": []
        },
        {
          "name": "Test No Active Stores Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Error message indicates no stores', function () {",
                  "    pm.expect(response.message).to.include('No active stores');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}?userLat=999&userLong=999",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"],
              "query": [
                {
                  "key": "userLat",
                  "value": "999",
                  "description": "Invalid latitude"
                },
                {
                  "key": "userLong",
                  "value": "999",
                  "description": "Invalid longitude"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Reference Data",
      "item": [
        {
          "name": "List Products (Get Product IDs)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Products list returned', function () {",
                  "    pm.expect(response.items).to.be.an('array');",
                  "    if (response.items.length > 0) {",
                  "        pm.collectionVariables.set('productId', response.items[0].id);",
                  "        console.log('First product ID:', response.items[0].id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?storeId={{storeId}}&page=1&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                {
                  "key": "storeId",
                  "value": "{{storeId}}"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Stores (Get Store ID)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Stores list returned', function () {",
                  "    pm.expect(response.data).to.be.an('array');",
                  "    if (response.data.length > 0) {",
                  "        pm.collectionVariables.set('storeId', response.data[0].id);",
                  "        console.log('First store ID:', response.data[0].id);",
                  "        console.log('Store name:', response.data[0].name);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/stores",
              "host": ["{{baseUrl}}"],
              "path": ["stores"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
