// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum Role {
  USER
  SUPER_ADMIN
  STORE_ADMIN
}

enum OrderStatus {
  WAITING_PAYMENT
  WAITING_CONFIRMATION
  PROCESSED
  SENT
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REJECTED
}

enum DiscountType {
  PERCENT
  NOMINAL
  B1G1
}

enum VoucherType {
  PRODUCT
  TOTAL
  SHIPPING
}

enum StockJournalType {
  IN
  OUT
  TRANSFER
  RETURN
}

enum VerificationTokenType {
  EMAIL_VERIFY
  RESET_PASSWORD
}

// ============================================
// FEATURE 1 (ANDREAS)
// ============================================
// USER & AUTH
// ============================================

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  password     String?
  name         String?
  phone        String?
  photo        String?
  role         Role         @default(USER)
  isVerified   Boolean      @default(false)
  referralCode String       @unique @default(uuid())
  referredBy   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  provider     AuthProvider @default(CREDENTIALS)

  // Relations
  addresses          Address[]
  carts              Cart[]
  orders             Order[]
  vouchers           Voucher[]
  referrals          User[]              @relation("ReferredUsers")
  referrer           User?               @relation("ReferredUsers", fields: [referredBy], references: [id])
  verificationTokens VerificationToken[]
  cronJobLogs        CronJobLog[]
  actionLogs         ActionLog[]

  managedStoreId String?
  managedStore   Store?  @relation(fields: [managedStoreId], references: [id])

  @@index([email])
  @@index([role])
  @@index([isVerified])
}

model VerificationToken {
  id        String                @id @default(uuid())
  token     String                @unique
  type      VerificationTokenType
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isUsed    Boolean               @default(false)
  createdAt DateTime              @default(now())
}

// ============================================
// USER ADDRESS
// ============================================

model Address {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  phone  String

  district   String
  detail     String
  postalCode String?
  isDefault  Boolean  @default(false)
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Keep these for display purposes (e.g., "DI Yogyakarta", "Bantul")
  province String
  city     String

  // ADD THESE for RajaOngkir API calls (e.g., "5", "39")
  provinceId String?
  cityId     String?
  orders Order[]
}

// ============================================
// FEATURE 2 (FIKRI)
// ============================================
// STORE & LOCATION
// ============================================

model Store {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  address     String
  province    String
  city        String
  district    String
  latitude    Float
  longitude   Float
  maxRadius   Float    @default(50) // km
  isMain      Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  admins        User[]
  stocks        Stock[]
  carts         Cart[]
  orders        Order[]
  discounts     Discount[]
  shippingCosts ShippingCost[]
}

// ============================================
// PRODUCT & CATEGORY
// ============================================

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  price       Decimal  @db.Decimal(10, 2)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  images     ProductImage[]
  stocks     Stock[]
  carts      Cart[]
  orderItems OrderItem[]
  discounts  Discount[]
  vouchers   Voucher[]

  @@index([categoryId])
  @@index([isActive])
  @@index([slug])
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ============================================
// INVENTORY & STOCK
// ============================================

model Stock {
  id        String   @id @default(uuid())
  productId String
  storeId   String
  quantity  Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id])
  store     Store    @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journals   StockJournal[]
  carts      Cart[]
  orderItems OrderItem[]

  @@unique([productId, storeId])
  @@index([productId])
  @@index([storeId])
}

model StockJournal {
  id        String           @id @default(uuid())
  stockId   String
  stock     Stock            @relation(fields: [stockId], references: [id])
  oldQty    Int
  newQty    Int
  change    Int
  type      StockJournalType
  reason    String?
  orderId   String?
  order     Order?           @relation(fields: [orderId], references: [id])
  userId    String
  createdAt DateTime         @default(now())

  @@index([stockId])
  @@index([createdAt])
  @@index([type])
}

// ============================================
// FEATURE 3 (ENDANG)
// ============================================
// DISCOUNT & VOUCHER
// ============================================

model Discount {
  id          String       @id @default(uuid())
  storeId     String
  store       Store        @relation(fields: [storeId], references: [id])
  productId   String?
  product     Product?     @relation(fields: [productId], references: [id])
  type        DiscountType
  value       Decimal      @db.Decimal(10, 2)
  minSpend    Decimal?     @db.Decimal(10, 2)
  maxDiscount Decimal?     @db.Decimal(10, 2)
  buyQty      Int? // For B1G1
  freeQty     Int? // For B1G1
  isActive    Boolean      @default(true)
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Voucher {
  id          String      @id @default(uuid())
  code        String      @unique
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  productId   String?
  product     Product?    @relation(fields: [productId], references: [id])
  type        VoucherType
  value       Decimal     @db.Decimal(10, 2)
  maxDiscount Decimal?    @db.Decimal(10, 2)
  minSpend    Decimal?    @db.Decimal(10, 2)
  qty         Int         @default(1) // Available quantity
  expiryDate  DateTime
  isUsed      Boolean     @default(false)
  usedAt      DateTime?
  orderId     String?
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([code])
  @@index([isUsed])
  @@index([expiryDate])
}

// ============================================
// SHOPPING CART
// ============================================

model Cart {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id])

  stockId String
  stock   Stock  @relation(fields: [stockId], references: [id])

  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, storeId])
  @@index([userId])
  @@index([storeId])
}

// ============================================
// ORDER & PAYMENT
// ============================================

model Order {
  id             String        @id @default(uuid())
  orderNumber    String        @unique
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  storeId        String
  store          Store         @relation(fields: [storeId], references: [id])
  addressId      String
  address        Address       @relation(fields: [addressId], references: [id])
  status         OrderStatus   @default(WAITING_PAYMENT)
  paymentStatus  PaymentStatus @default(PENDING)
  subtotal       Decimal       @db.Decimal(10, 2)
  shippingCost   Decimal       @db.Decimal(10, 2)
  discountAmount Decimal       @db.Decimal(10, 2)
  totalAmount    Decimal       @db.Decimal(10, 2)
  paymentProof   String?
  paymentMethod  String?
  notes          String?
  createdAt      DateTime      @default(now())
  paidAt         DateTime?
  sentAt         DateTime?
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  cancelledBy    String? // USER or ADMIN
  cancelReason   String?

  items         OrderItem[]
  stockJournals StockJournal[]

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  stockId   String
  stock     Stock   @relation(fields: [stockId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
}

// ============================================
// SHIPPING COST CACHE
// ============================================

model ShippingCost {
  id            String   @id @default(uuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  destination   String // City/District
  province      String
  city          String
  district      String
  courier       String // JNE, POS, etc
  service       String // REG, OKE, YES
  cost          Decimal  @db.Decimal(10, 2)
  estimatedDays Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([storeId, destination, courier, service])
}

// ============================================
// CRON JOB LOGS
// ============================================

model CronJobLog {
  id         String   @id @default(uuid())
  jobName    String
  executedBy String?
  status     String // SUCCESS, FAILED
  message    String?
  executedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

// ============================================
// AUDIT LOGGING
// ============================================

model ActionLog {
  id         String   @id @default(uuid())
  action     String // e.g., "CREATE_STORE_ADMIN", "UPDATE_STORE_ADMIN"
  targetId   String? // The ID of the record being changed
  targetType String? // e.g., "User", "Store"
  details    Json? // Additional information about the action
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// ============================================
// PROMOTIONAL BANNERS
// ============================================

model Banner {
  id           String   @id @default(uuid())
  title        String
  subtitle     String?
  imageUrl     String?  // Optional if using gradient
  bgGradient   String?  // e.g. "bg-gradient-to-r from-primary to-accent"
  contentColor String   @default("text-white")
  linkUrl      String?
  showText     Boolean  @default(true)
  isActive     Boolean  @default(true)
  discountId   String?  // Linked discount if this is an override
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([discountId])
}

