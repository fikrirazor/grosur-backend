// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum Role {
  USER
  SUPER_ADMIN
  STORE_ADMIN
}

enum OrderStatus {
  WAITING_PAYMENT
  WAITING_CONFIRMATION
  PROCESSED
  SENT
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REJECTED
}

enum DiscountType {
  PERCENT
  NOMINAL
  B1G1
}

enum VoucherType {
  PRODUCT
  TOTAL
  SHIPPING
}

enum StockJournalType {
  IN
  OUT
  TRANSFER
  RETURN
}

enum VerificationTokenType {
  EMAIL_VERIFY
  RESET_PASSWORD
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String?
  name          String?
  phone         String?
  photo         String?
  role          Role      @default(USER)
  isVerified    Boolean   @default(false)
  referralCode  String    @unique @default(uuid())
  referredBy    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  addresses     Address[]
  carts         Cart[]
  orders        Order[]
  vouchers      Voucher[]
  referrals     User[]    @relation("ReferredUsers")
  referrer      User?     @relation("ReferredUsers", fields: [referredBy], references: [id])
  verificationTokens VerificationToken[]
  cronJobLogs   CronJobLog[]
}

model VerificationToken {
  id        String              @id @default(uuid())
  token     String              @unique
  type      VerificationTokenType
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isUsed    Boolean             @default(false)
  createdAt DateTime            @default(now())
}

// ============================================
// USER ADDRESS
// ============================================

model Address {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  phone      String
  province   String
  city       String
  district   String
  detail     String
  postalCode String?
  isDefault  Boolean  @default(false)
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orders     Order[]
}

// ============================================
// STORE & LOCATION
// ============================================

model Store {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  address     String
  province    String
  city        String
  district    String
  latitude    Float
  longitude   Float
  maxRadius   Float    @default(50) // km
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  admins      User[]
  stocks      Stock[]
  carts       Cart[]
  orders      Order[]
  discounts   Discount[]
  shippingCosts ShippingCost[]
}

// ============================================
// PRODUCT & CATEGORY
// ============================================

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  price       Decimal  @db.Decimal(10, 2)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  images      ProductImage[]
  stocks      Stock[]
  carts       Cart[]
  orderItems  OrderItem[]
  discounts   Discount[]
  vouchers    Voucher[]
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ============================================
// INVENTORY & STOCK
// ============================================

model Stock {
  id        String   @id @default(uuid())
  productId String
  storeId   String
  quantity  Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id])
  store     Store    @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journals  StockJournal[]
  carts     Cart[]
  orderItems OrderItem[]

  @@unique([productId, storeId])
}

model StockJournal {
  id        String           @id @default(uuid())
  stockId   String
  stock     Stock            @relation(fields: [stockId], references: [id])
  oldQty    Int
  newQty    Int
  change    Int
  type      StockJournalType
  reason    String?
  orderId   String?
  userId    String
  createdAt DateTime         @default(now())
}

// ============================================
// DISCOUNT & VOUCHER
// ============================================

model Discount {
  id          String      @id @default(uuid())
  storeId     String
  store       Store       @relation(fields: [storeId], references: [id])
  productId   String?
  product     Product?    @relation(fields: [productId], references: [id])
  type        DiscountType
  value       Decimal     @db.Decimal(10, 2)
  minSpend    Decimal?    @db.Decimal(10, 2)
  maxDiscount Decimal?    @db.Decimal(10, 2)
  buyQty      Int?        // For B1G1
  freeQty     Int?        // For B1G1
  isActive    Boolean     @default(true)
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Voucher {
  id          String     @id @default(uuid())
  code        String     @unique
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  productId   String?
  product     Product?   @relation(fields: [productId], references: [id])
  type        VoucherType
  value       Decimal    @db.Decimal(10, 2)
  maxDiscount Decimal?   @db.Decimal(10, 2)
  minSpend    Decimal?   @db.Decimal(10, 2)
  expiryDate  DateTime
  isUsed      Boolean    @default(false)
  usedAt      DateTime?
  orderId     String?
  createdAt   DateTime   @default(now())
}

// ============================================
// SHOPPING CART
// ============================================

model Cart {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, storeId])
}

// ============================================
// ORDER & PAYMENT
// ============================================

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  storeId         String
  store           Store         @relation(fields: [storeId], references: [id])
  addressId       String
  address         Address       @relation(fields: [addressId], references: [id])
  status          OrderStatus   @default(WAITING_PAYMENT)
  paymentStatus   PaymentStatus @default(PENDING)
  subtotal        Decimal       @db.Decimal(10, 2)
  shippingCost    Decimal       @db.Decimal(10, 2)
  discountAmount  Decimal       @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  paymentProof    String?
  paymentMethod   String?
  notes           String?
  createdAt       DateTime      @default(now())
  paidAt          DateTime?
  sentAt          DateTime?
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelledBy     String?       // USER or ADMIN
  cancelReason    String?

  items           OrderItem[]
  stockJournals   StockJournal[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  stockId   String
  stock     Stock    @relation(fields: [stockId], references: [id])
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  discount  Decimal  @db.Decimal(10, 2) @default(0)
  subtotal  Decimal  @db.Decimal(10, 2)
}

// ============================================
// SHIPPING COST CACHE
// ============================================

model ShippingCost {
  id            String   @id @default(uuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  destination   String   // City/District
  province      String
  city          String
  district      String
  courier       String   // JNE, POS, etc
  service       String   // REG, OKE, YES
  cost          Decimal  @db.Decimal(10, 2)
  estimatedDays Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([storeId, destination, courier, service])
}

// ============================================
// CRON JOB LOGS
// ============================================

model CronJobLog {
  id        String   @id @default(uuid())
  jobName   String
  executedBy String?
  status    String   // SUCCESS, FAILED
  message   String?
  executedAt DateTime @default(now())
}

// ============================================
// INDEXES FOR PERFORMANCE
// ============================================

// User indexes
@@index([User.email])
@@index([User.role])
@@index([User.isVerified])

// Order indexes
@@index([Order.userId])
@@index([Order.storeId])
@@index([Order.status])
@@index([Order.createdAt])
@@index([Order.orderNumber])

// Product indexes
@@index([Product.categoryId])
@@index([Product.isActive])
@@index([Product.slug])

// Stock indexes
@@index([Stock.productId])
@@index([Stock.storeId])

// StockJournal indexes
@@index([StockJournal.stockId])
@@index([StockJournal.createdAt])
@@index([StockJournal.type])

// Voucher indexes
@@index([Voucher.userId])
@@index([Voucher.code])
@@index([Voucher.isUsed])
@@index([Voucher.expiryDate])

// Cart indexes
@@index([Cart.userId])
@@index([Cart.storeId])
